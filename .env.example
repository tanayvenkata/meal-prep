# Anthropic — powers the streaming chat (M1). Server-side only.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase Postgres — the pantry database (M3). Server-side ONLY (no NEXT_PUBLIC_
# prefix), because it contains the DB password. Use the TRANSACTION POOLER URI
# (port 6543, ...pooler.supabase.com) — built for serverless (Vercel) functions.
DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres

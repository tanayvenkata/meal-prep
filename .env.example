# Secrets are managed in Doppler (meal-prep project).
# Run `doppler setup` then `doppler run -- npm run dev` to inject secrets locally.
# Add new secrets in Doppler — they sync to Vercel automatically.
#
# The only secret that lives in .env.local (not Doppler) is TEST_DATABASE_URL,
# because it points to 127.0.0.1 (local Supabase) and is only used by integration tests.

# --- Doppler: meal-prep / dev + prd ---
# Get values from: dashboard.doppler.com → meal-prep → dev

# Anthropic — powers the streaming chat. Server-side only.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase Postgres — application pool as the dedicated `mise_app` role (issue #64).
# Not the table-owner `postgres` role. Use the TRANSACTION POOLER URI (port 6543).
# Provision password with: ADMIN_DATABASE_URL=... MISE_APP_DB_PASSWORD=... npm run db:provision-app-role
DATABASE_URL=postgresql://mise_app.[YOUR-PROJECT-REF]:[MISE-APP-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres

# Supabase Auth — project URL and publishable key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# --- .env.local only (not in Doppler) ---
# Local Supabase: app role + owner/admin for rare ops. Seed sets mise_app password.
# Run `supabase start` (or `db reset`) first. Integration tests also set these via vitest.config.ts.
DATABASE_URL=postgresql://mise_app:mise_app_local@127.0.0.1:54322/postgres
ADMIN_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

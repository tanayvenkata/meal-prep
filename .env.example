# Anthropic — powers the streaming chat (M1). Server-side only.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase Postgres — the pantry database (M3). Server-side ONLY (no NEXT_PUBLIC_
# prefix), because it contains the DB password. Use the TRANSACTION POOLER URI
# (port 6543, ...pooler.supabase.com) — built for serverless (Vercel) functions.
DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres

# Supabase Auth — project URL and anon key (M5). NEXT_PUBLIC_ prefix means these
# are safe to expose to the browser. The anon key is not a secret — RLS protects
# the data, not this key. Find both in Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# .env.example — TEMPLATE, committed to git. Contains NO real secrets.
# Its job: tell anyone (including future-you on a new machine) which env vars
# the app needs. To set up, copy this file to .env.local and fill in real values:
#   cp .env.example .env.local
#
# .env.local is git-ignored and never leaves your machine.

# Your Anthropic API key. Get one at https://console.anthropic.com (API Keys).
# Starts with sk-ant-...  Keep it secret; never commit it; never paste it anywhere
# but .env.local. If it ever leaks, revoke it and create a new one.
ANTHROPIC_API_KEY=sk-ant-your-key-here

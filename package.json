{
  "name": "meal-prep",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "doppler run -- next dev",
    "prebuild": "npm run mcp:widget",
    "build": "next build",
    "build:local": "doppler run -- next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:unit": "vitest --run src/__tests__/api src/__tests__/lib/auth.test.ts src/__tests__/lib/theme.test.ts src/__tests__/middleware.test.ts src/__tests__/mcp",
    "test:integration": "vitest --run src/__tests__/lib",
    "db:provision-app-role": "node scripts/provision-mise-app-role.mjs",
    "mcp:widget": "tsx scripts/build-mcp-widget.ts",
    "mcp:serve": "tsx watch --include 'src/mcp/kitchen-widget.*' src/mcp/standalone.ts",
    "mcp:dev": "doppler run -- npm run mcp:serve",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.13.5",
    "@openai/apps-sdk-ui": "^0.2.2",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/typography": "^0.5.20",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "express": "^5.2.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
